# ─── App ───────────────────────────────────────────────────────────────
# Public URL the app is served from (used for OAuth callbacks + exports).
APP_URL=https://notes.glacianav.com
# Canonical URL Auth.js uses to build sign-in/out redirects. MUST be set to the
# public URL behind a proxy/tunnel, or redirects fall back to the container's
# internal address (e.g. https://0.0.0.0:3000). Same value as APP_URL.
AUTH_URL=https://notes.glacianav.com
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-openssl-rand-base64-32

# First admin, seeded on first boot (`npm run db:seed`). No public signup exists.
ADMIN_EMAIL=admin@glacianav.com
ADMIN_PASSWORD=change-me-strong-password

# ─── Postgres (pgvector) ───────────────────────────────────────────────
POSTGRES_USER=glacia
POSTGRES_PASSWORD=change-me
POSTGRES_DB=glacianotes
# Compose injects DATABASE_URL from the above; for local dev outside Docker:
DATABASE_URL=postgres://glacia:change-me@localhost:5432/glacianotes

# ─── Redis (BullMQ queue) ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Object storage (MinIO, S3-compatible) ─────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=glacia-minio
S3_SECRET_KEY=change-me
S3_BUCKET=glacianav-audio
S3_REGION=us-east-1

# ─── AssemblyAI (transcription) ────────────────────────────────────────
ASSEMBLYAI_API_KEY=your-assemblyai-key
# Shared secret we send with the transcription request and verify on the webhook.
ASSEMBLYAI_WEBHOOK_SECRET=change-me-random

# ─── DeepSeek (summaries / action items / Q&A) ─────────────────────────
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-flash

# ─── Embeddings (bge-small, runs locally in the worker via transformers.js) ──
EMBEDDING_MODEL=Xenova/bge-small-en-v1.5
# Transcripts longer than this many characters use chunked retrieval for Q&A.
QA_RETRIEVAL_THRESHOLD=12000

# ─── Google Docs export (OAuth) ────────────────────────────────────────
# Create an OAuth client (type: Web) in Google Cloud Console and add the
# redirect URI: ${APP_URL}/api/connect/google/callback . Scope used: drive.file.
# Leave blank to hide Google export.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft Teams export ────────────────────────────────────────────
# No server config needed. Each user pastes a Teams channel *incoming webhook*
# (Workflows) URL under Settings → Integrations; notes post as an Adaptive Card.

# ─── Cloudflare Tunnel ─────────────────────────────────────────────────
# Named-tunnel token from the Cloudflare Zero Trust dashboard.
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
